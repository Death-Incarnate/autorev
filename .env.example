# autorev — LLM provider configuration
# Copy to .env and fill in your key for at least one provider

# NVIDIA NIM (free tier: 5000 credits, 40 RPM)
NVIDIA_API_KEY=nvapi-xxx

# Cerebras (free tier available)
CEREBRAS_API_KEY=csk-xxx

# OpenRouter (pay-per-use, many models)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Anthropic (pay-per-use)
ANTHROPIC_API_KEY=sk-ant-xxx

# Default provider (nvidia, cerebras, openrouter, anthropic)
AUTOREV_PROVIDER=nvidia
